# ===== Backend =====
DATABASE_URL=postgresql://postgres:password@localhost:5432/gigshield
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRY=7d
PORT=3000

# ===== Redis =====
REDIS_HOST=localhost
